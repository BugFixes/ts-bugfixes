{
  "name": "bugfixes",
  "version": "2.0.0",
  "description": "TypeScript logging, error tracking, and HTTP middleware library for Bugfixes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "bugfixes",
    "logging",
    "middleware",
    "error-tracking"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logs": {
      "types": "./dist/logs/index.d.ts",
      "default": "./dist/logs/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "default": "./dist/middleware/index.js"
    }
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "uuid": "^13.0.0"
  }
}
